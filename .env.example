# Session encryption key — generate with: openssl rand -base64 48 | tr -dc A-Za-z0-9 | head -c32
# Must be at least 32 characters long
NUXT_SESSION_PASSWORD=

# Resend API key for transactional emails (https://resend.com)
# Leave blank to skip sending (emails will be logged instead)
RESEND_API_KEY=
